---
import BaseLayout from '../../layouts/BaseLayout.astro'

const email = 'weiran@zhang.me.uk'

const socialLinks = [
  {
    label: 'GitHub',
    href: 'https://github.com/weiran',
    icon: 'github',
  },
  {
    label: 'LinkedIn',
    href: 'https://www.linkedin.com/in/weiranz',
    icon: 'linkedin',
  },
  {
    label: 'Mastodon',
    href: 'https://mastodon.social/@weiran',
    icon: 'mastodon',
    rel: 'me',
  },
  {
    label: 'Twitter / X',
    href: 'https://twitter.com/weiran',
    icon: 'twitter',
  },
]
---

<BaseLayout title="Contact" description="Get in touch with Weiran Zhang." wide>
  <article class="contact-page">
    <section class="contact-grid" aria-labelledby="contact-title">
      <div class="contact-primary">
        <p class="eyebrow">Contact</p>
        <h1 id="contact-title">Get in touch.</h1>
        <p>The best way to get in touch is by email.</p>

        <a href={`mailto:${email}`} class="contact-email-card">
          <span class="contact-icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" role="img">
              <path d="M7.5 12.5h33v24h-33z" />
              <path d="m8.5 14 15.5 13 15.5-13" />
            </svg>
          </span>
          <span>{email}</span>
          <span aria-hidden="true">→</span>
        </a>
      </div>

      <aside class="contact-elsewhere" aria-labelledby="elsewhere-title">
        <p id="elsewhere-title" class="eyebrow">Elsewhere</p>
        <div class="social-link-list">
          {
            socialLinks.map((link) => (
              <a href={link.href} rel={link.rel} class="social-link-card">
                <span class={`contact-icon contact-icon--${link.icon}`} aria-hidden="true">
                  {link.icon === 'github' && (
                    <svg viewBox="0 0 48 48" role="img">
                      <path d="M24 4.5c-10.8 0-19.5 8.7-19.5 19.5 0 8.6 5.6 15.9 13.3 18.5 1 .2 1.3-.4 1.3-.9v-3.5c-5.4 1.2-6.5-2.3-6.5-2.3-.9-2.2-2.1-2.8-2.1-2.8-1.8-1.2.1-1.2.1-1.2 1.9.1 3 2 3 2 1.7 3 4.6 2.1 5.7 1.6.2-1.2.7-2.1 1.2-2.6-4.3-.5-8.8-2.2-8.8-9.6 0-2.1.8-3.9 2-5.2-.2-.5-.9-2.5.2-5.1 0 0 1.6-.5 5.4 2 1.6-.4 3.2-.7 4.8-.7s3.3.2 4.8.7c3.7-2.5 5.4-2 5.4-2 1.1 2.6.4 4.6.2 5.1 1.3 1.4 2 3.1 2 5.2 0 7.5-4.5 9.1-8.8 9.6.7.6 1.3 1.8 1.3 3.6v5.2c0 .5.3 1.1 1.3.9 7.7-2.6 13.3-9.9 13.3-18.5C43.5 13.2 34.8 4.5 24 4.5z" />
                    </svg>
                  )}
                  {link.icon === 'linkedin' && (
                    <svg viewBox="0 0 48 48" role="img">
                      <path d="M9.5 9.5h29v29h-29z" />
                      <path d="M16 21.5v10" />
                      <path d="M16 16.5v.2" />
                      <path d="M23 31.5v-10" />
                      <path d="M23 25.5c.7-2.5 2.4-4 5-4 3.2 0 5 2.1 5 5.8v4.2" />
                    </svg>
                  )}
                  {link.icon === 'mastodon' && (
                    <svg viewBox="0 0 48 48" role="img">
                      <path d="M13.5 30.5c.5 4.1 3.8 6.2 9.9 6.2 2.9 0 5.4-.4 7.6-1.2" />
                      <path d="M34.8 29.2c2.2-.3 4.1-1 4.6-1.8 1.1-1.8 1.4-8.2.8-11.1-.9-4.4-4.8-7.3-10.1-7.8H18c-5.4.5-9.4 3.4-10.2 7.8-.5 3-.3 8.4.6 12.5 1.1 5.1 5.1 8.6 12 9.4l.7.1v-5.2" />
                      <path d="M15.2 27.5V17.2c0-2.2 1.8-4 4-4 2.4 0 4 1.3 4.8 3.4.8-2.1 2.4-3.4 4.8-3.4 2.2 0 4 1.8 4 4v10.3" />
                      <path d="M23.9 18.8v7.7" />
                    </svg>
                  )}
                  {link.icon === 'twitter' && (
                    <svg viewBox="0 0 48 48" role="img">
                      <path d="M41 13.4c-1.2.6-2.5 1-3.9 1.2 1.4-.8 2.4-2 2.9-3.6-1.3.8-2.8 1.4-4.3 1.7-1.3-1.4-3-2.2-5-2.2-3.8 0-6.8 3.1-6.8 6.8 0 .5.1 1.1.2 1.5-5.6-.3-10.7-3-14-7.2-.6 1-.9 2.1-.9 3.4 0 2.4 1.2 4.5 3 5.7-1.1 0-2.2-.3-3.1-.8v.1c0 3.3 2.3 6 5.4 6.7-.6.2-1.2.2-1.8.2-.4 0-.9 0-1.3-.1.9 2.7 3.4 4.6 6.4 4.7-2.3 1.8-5.2 2.9-8.4 2.9H8c3 1.9 6.5 3 10.3 3 12.3 0 19-10.2 19-19v-.9c1.4-.9 2.6-2.1 3.7-3.8z" />
                    </svg>
                  )}
                </span>
                <span>{link.label}</span>
                <span aria-hidden="true">→</span>
              </a>
            ))
          }
        </div>
      </aside>
    </section>
  </article>
</BaseLayout>
