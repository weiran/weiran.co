---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import TitleLink from '../components/TitleLink.astro'
import { site } from '../config/site'
import { excerpt } from '../lib/text'

const postsPerPage = 12

const posts = (await getCollection('blog'))
  .filter((p) => p.data.type !== 'page' && !p.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

const latestPosts = posts.slice(0, 4)
const featured = latestPosts[0]
const numPages = Math.ceil(posts.length / postsPerPage)

const readTime = (body: string) =>
  `${Math.max(1, Math.ceil(body.trim().split(/\s+/).length / 220))} min read`
const homeDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  }).format(date)
const summary = (body: string) => {
  const text = excerpt(body)
  return text.length > 180 ? `${text.slice(0, 177).trim()}…` : text
}
---

<BaseLayout description={site.description} wide>
  <section class="home-hero" aria-labelledby="home-title">
    <div class="home-hero-copy">
      <h1 id="home-title">Weiran Zhang</h1>
      <p>
        I write about technology, software engineering, side projects, and
        building thoughtful products.
      </p>
      {
        featured ? (
          <a class="text-link text-link--ruled" href={`/blog/${featured.slug}`}>
            Read the latest post <span aria-hidden="true">→</span>
          </a>
        ) : null
      }
    </div>

    {
      featured ? (
        <article class="featured-card" aria-labelledby="featured-title">
          <p class="eyebrow">Featured Post</p>
          <h2 id="featured-title">
            <TitleLink
              title={featured.data.title}
              passthroughUrl={featured.data.passthroughUrl}
              slug={featured.slug}
            />
          </h2>
          <p>{featured.data.description ?? summary(featured.body)}</p>
          <div class="featured-card-footer">
            <p>
              {homeDate(featured.data.date)} · {readTime(featured.body)}
            </p>
            <a class="text-link" href={`/blog/${featured.slug}`}>
              Read post <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      ) : null
    }
  </section>

  <section class="home-grid" aria-label="Latest writing and about">
    <div class="latest-panel">
      <p class="eyebrow">Latest Writing</p>
      <ol class="latest-list">
        {
          latestPosts.map((post) => (
            <li>
              <a href={post.data.passthroughUrl ?? `/blog/${post.slug}`}>
                {post.data.title}
              </a>
              <time datetime={post.data.date.toISOString()}>
                {homeDate(post.data.date)}
              </time>
            </li>
          ))
        }
      </ol>
      {
        numPages > 1 ? (
          <a class="text-link" href="/blog/page/2" rel="next">
            View all posts <span aria-hidden="true">→</span>
          </a>
        ) : null
      }
    </div>

    <aside class="about-panel" aria-labelledby="about-title">
      <p class="eyebrow" id="about-title">About</p>
      <p>
        Software engineer by day, builder by night. I care about clarity,
        simplicity, and making things that are genuinely useful.
      </p>
    </aside>
  </section>

  <section class="project-strip" aria-labelledby="project-title">
    <div>
      <p class="eyebrow">Projects</p>
      <h2 id="project-title">Hackers</h2>
      <p>A minimalist Hacker News reader with keyboard-first navigation.</p>
    </div>
    <dl class="project-stats">
      <div>
        <dt>100k+</dt>
        <dd>Total downloads</dd>
      </div>
      <div>
        <dt>747</dt>
        <dd>GitHub stars</dd>
      </div>
      <div>
        <dt>16</dt>
        <dd>GitHub contributors</dd>
      </div>
    </dl>
    <a class="text-link" href="/projects/hackers"
      >Explore project <span aria-hidden="true">→</span></a
    >
  </section>
</BaseLayout>
