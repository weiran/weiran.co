---
import { Image } from 'astro:assets'
import BaseLayout from '../../../layouts/BaseLayout.astro'
import hackersHero from './_hackers-phones.png'

const appStoreUrl = 'https://apps.apple.com/app/hackers/id603503901'
const githubUrl = 'https://github.com/weiran/Hackers'

const stats = [
  ['Price', 'Free'],
  ['Rating', '4.6 ★'],
  ['Ratings', '411'],
  ['Platforms', 'iPhone + iPad'],
  ['License', 'MIT'],
  ['Language', 'Swift'],
]

const features = [
  {
    title: 'Built for speed',
    description: 'Lightning-fast browsing with instant loading and smooth scrolling.',
    icon: 'bolt',
  },
  {
    title: 'Threaded comments',
    description: 'Beautifully indented comment threads make conversations easy to follow.',
    icon: 'message',
  },
  {
    title: 'Native to iOS',
    description: 'Unapologetically built with native controls, gestures, and platform conventions.',
    icon: 'swipe',
  },
  {
    title: 'Light & dark mode',
    description: 'Gorgeous in any light. Automatic dark mode support included.',
    icon: 'theme',
  },
]
---

<BaseLayout
  title="Hackers"
  description="A clean, fast Hacker News reader for iPhone and iPad."
  wide
>
  <article class="project-detail">
    <section class="project-detail-hero" aria-labelledby="project-title">
      <div class="project-detail-copy">
        <span class="project-app-icon" aria-hidden="true">
          <svg viewBox="0 0 48 48" role="img">
            <path d="m15 11 11 13-11 13" />
            <path d="M28.5 37h10" />
          </svg>
        </span>
        <p class="eyebrow">Project</p>
        <h1 id="project-title">Hackers</h1>
        <p class="project-detail-tagline">
          A clean, fast Hacker News reader for iPhone and iPad.
        </p>
        <div class="project-actions">
          <a href={appStoreUrl} class="button-link">
            View on App Store <span aria-hidden="true">↗</span>
          </a>
          <a href={githubUrl} class="button-link button-link--secondary">
            <span class="button-icon" aria-hidden="true">
              <svg viewBox="0 0 48 48" role="img">
                <path d="M24 4.5c-10.8 0-19.5 8.7-19.5 19.5 0 8.6 5.6 15.9 13.3 18.5 1 .2 1.3-.4 1.3-.9v-3.5c-5.4 1.2-6.5-2.3-6.5-2.3-.9-2.2-2.1-2.8-2.1-2.8-1.8-1.2.1-1.2.1-1.2 1.9.1 3 2 3 2 1.7 3 4.6 2.1 5.7 1.6.2-1.2.7-2.1 1.2-2.6-4.3-.5-8.8-2.2-8.8-9.6 0-2.1.8-3.9 2-5.2-.2-.5-.9-2.5.2-5.1 0 0 1.6-.5 5.4 2 1.6-.4 3.2-.7 4.8-.7s3.3.2 4.8.7c3.7-2.5 5.4-2 5.4-2 1.1 2.6.4 4.6.2 5.1 1.3 1.4 2 3.1 2 5.2 0 7.5-4.5 9.1-8.8 9.6.7.6 1.3 1.8 1.3 3.6v5.2c0 .5.3 1.1 1.3.9 7.7-2.6 13.3-9.9 13.3-18.5C43.5 13.2 34.8 4.5 24 4.5z" />
              </svg>
            </span>
            View on GitHub <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <figure class="project-detail-media project-detail-media--phones">
        <Image
          src={hackersHero}
          alt="Hackers app screens showing threaded comments and the story list"
          width={1220}
          height={900}
          loading="eager"
          decoding="async"
        />
      </figure>
    </section>

    <dl class="project-detail-stats">
      {
        stats.map(([label, value]) => (
          <div>
            <dt>{label}</dt>
            <dd>{value}</dd>
          </div>
        ))
      }
    </dl>

    <section class="project-feature-section" aria-labelledby="features-title">
      <p id="features-title" class="eyebrow">Why people use it</p>
      <div class="project-feature-grid">
        {
          features.map((feature) => (
            <article class="project-feature-card">
              <span class={`feature-icon feature-icon--${feature.icon}`} aria-hidden="true">
                {feature.icon === 'bolt' && (
                  <svg viewBox="0 0 48 48" role="img">
                    <path d="M27 4 10.5 27h12L18 44l18-25H23.5z" />
                  </svg>
                )}
                {feature.icon === 'message' && (
                  <svg viewBox="0 0 48 48" role="img">
                    <path d="M10 14.5c0-4 3.6-7 8.4-7h11.2c4.8 0 8.4 3 8.4 7v7c0 4-3.6 7-8.4 7H22l-8.5 7v-7.8C11.3 26.5 10 24.3 10 21.5z" />
                    <path d="M18 18h.1" />
                    <path d="M24 18h.1" />
                    <path d="M30 18h.1" />
                  </svg>
                )}
                {feature.icon === 'swipe' && (
                  <svg viewBox="0 0 48 48" role="img">
                    <path d="M25 6v20" />
                    <path d="M18 16v11" />
                    <path d="M32 18v10" />
                    <path d="M12 24v8c0 6.2 5 11 11.4 11H28c5.5 0 10-4.5 10-10v-5" />
                    <path d="m38 13 4 4-4 4" />
                    <path d="M30 17h12" />
                  </svg>
                )}
                {feature.icon === 'theme' && (
                  <svg viewBox="0 0 48 48" role="img">
                    <path d="M17 11v-5" />
                    <path d="M17 38v4" />
                    <path d="M6 24h5" />
                    <path d="M23.5 17.5 27 14" />
                    <path d="M7.5 13.5 11 17" />
                    <path d="M7.5 34.5 11 31" />
                    <path d="M17 16.5a7.5 7.5 0 1 0 0 15" />
                    <path d="M33.5 7 19 41" />
                    <path d="M32 14.5c-3.3 3.1-5 7-5 11.5 0 5.4 4.3 9.8 9.7 9.8 1.9 0 3.7-.5 5.3-1.5-1.3 3.3-4.5 5.7-8.2 5.7-5.7 0-10.3-4.6-10.3-10.3 0-6.7 3.3-11.9 8.5-15.2z" />
                  </svg>
                )}
              </span>
              <div>
                <h2>{feature.title}</h2>
                <p>{feature.description}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="project-detail-lower">
      <div class="project-overview">
        <p class="eyebrow">Overview</p>
        <p>
          Hackers is for people who actually read the comments. It removes
          distractions so you can focus on what matters: great discussions and
          interesting ideas. From power users to casual readers, Hackers makes
          Hacker News a joy to browse on iPhone and iPad.
        </p>
      </div>

      <aside class="open-source-panel" aria-labelledby="open-source-title">
        <p id="open-source-title" class="eyebrow">Open source</p>
        <div class="open-source-body">
          <span class="callout-icon" aria-hidden="true">
            <svg viewBox="0 0 48 48" role="img">
              <path d="M24 4.5c-10.8 0-19.5 8.7-19.5 19.5 0 8.6 5.6 15.9 13.3 18.5 1 .2 1.3-.4 1.3-.9v-3.5c-5.4 1.2-6.5-2.3-6.5-2.3-.9-2.2-2.1-2.8-2.1-2.8-1.8-1.2.1-1.2.1-1.2 1.9.1 3 2 3 2 1.7 3 4.6 2.1 5.7 1.6.2-1.2.7-2.1 1.2-2.6-4.3-.5-8.8-2.2-8.8-9.6 0-2.1.8-3.9 2-5.2-.2-.5-.9-2.5.2-5.1 0 0 1.6-.5 5.4 2 1.6-.4 3.2-.7 4.8-.7s3.3.2 4.8.7c3.7-2.5 5.4-2 5.4-2 1.1 2.6.4 4.6.2 5.1 1.3 1.4 2 3.1 2 5.2 0 7.5-4.5 9.1-8.8 9.6.7.6 1.3 1.8 1.3 3.6v5.2c0 .5.3 1.1 1.3.9 7.7-2.6 13.3-9.9 13.3-18.5C43.5 13.2 34.8 4.5 24 4.5z" />
            </svg>
          </span>
          <div>
            <p>
              Hackers is 100% open source and built in the open. Contributions
              and feedback are always welcome.
            </p>
            <div class="repo-meta">
              <span>☆ 747 stars</span>
              <span>⑂ 104 forks</span>
              <a href={githubUrl} class="text-link">
                View repository <span aria-hidden="true">→</span>
              </a>
            </div>
          </div>
        </div>
      </aside>
    </section>
  </article>
</BaseLayout>
