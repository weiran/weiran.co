---
import BaseLayout from '../../layouts/BaseLayout.astro'

const featuredProjects = [
  {
    title: 'Hackers',
    description: 'An open source Hacker News reader for iOS.',
    href: '/projects/hackers',
    icon: 'terminal',
  },
]

const archiveProjects = [
  {
    title: 'Drank',
    description: 'A simple app to help you drink better.',
    year: '2018',
    href: 'http://thedrankapp.com',
  },
  {
    title: 'Watch It Later',
    description: 'Save online videos to watch later on your Apple TV.',
    year: '2016',
    href: '/projects/watch-it-later',
  },
  {
    title: 'Infinite Loop',
    description: 'iOS game focused on reactions and high scores.',
    year: '2014',
    href: '/projects/infinite-loop',
  },
  {
    title: 'Castr',
    description: 'A social podcasting app built with Node.js.',
    year: '2013',
    href: 'http://castr.net',
  },
  {
    title: 'NSClippy',
    description: 'Clippy, but for your iOS app.',
    year: '2012',
    href: 'https://github.com/weiran/NSClippy',
  },
  {
    title: 'NSWhatever',
    description: 'A blog about Cocoa and Objective-C.',
    year: '2012',
    href: 'http://nswhatever.com',
  },
  {
    title: 'First Issue',
    description: 'Newsstand publishing for everyone.',
    year: '2011',
    href: 'http://www.firstissue.co',
  },
  {
    title: 'Metropaper',
    description: 'An Instapaper app for Windows Phone.',
    year: '2011',
    href: 'https://github.com/weiran/Metropaper',
  },
  {
    title: 'Twitterlicious',
    description: 'One of the earliest Twitter apps for Windows.',
    year: '2010',
    href: 'http://www.ejecutive.co.uk/projects/twitterlicious',
  },
]
---

<BaseLayout title="Projects" description="Products, apps, and experiments by Weiran Zhang." wide>
  <article class="projects-page">
    <header class="projects-hero">
      <p class="eyebrow">Projects</p>
      <h1>Things I&rsquo;ve built.</h1>
      <p>
        A selection of products, apps, and experiments I&rsquo;ve designed, built,
        and shipped.
      </p>
    </header>

    <section class="featured-projects" aria-labelledby="featured-projects-title">
      <h2 id="featured-projects-title">Featured projects</h2>
      <div class="featured-project-grid">
        {
          featuredProjects.map((project) => (
            <a href={project.href} class="project-card">
              <span class={`project-card-icon project-card-icon--${project.icon}`} aria-hidden="true">
                {project.icon === 'terminal' && (
                  <svg viewBox="0 0 48 48" role="img">
                    <path d="M7.5 9.5h33v29h-33z" />
                    <path d="m15 19 6 5-6 5" />
                    <path d="M25.5 29.5h9" />
                  </svg>
                )}
                {project.icon === 'screen' && (
                  <svg viewBox="0 0 48 48" role="img">
                    <path d="M9 10.5h30v25H9z" />
                    <path d="M19 40.5h10" />
                    <path d="M24 35.5v5" />
                  </svg>
                )}
                {project.icon === 'drop' && (
                  <svg viewBox="0 0 48 48" role="img">
                    <path d="M24 5.5c6.6 8.1 11.5 15 11.5 22.2 0 7.1-5.2 12.8-11.5 12.8s-11.5-5.7-11.5-12.8C12.5 20.5 17.4 13.6 24 5.5z" />
                  </svg>
                )}
              </span>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <span class="text-link">
                View project <span aria-hidden="true">→</span>
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <section class="project-archive" aria-labelledby="project-archive-title">
      <h2 id="project-archive-title">Archive</h2>
      <div class="archive-list">
        {
          archiveProjects.map((project) => (
            <a href={project.href} class="archive-row">
              <strong>{project.title}</strong>
              <span>{project.description}</span>
              <time>{project.year}</time>
            </a>
          ))
        }
      </div>
    </section>

    <section class="project-callouts" aria-label="Project links">
      <a href="https://github.com/weiran" class="project-callout">
        <span class="callout-icon" aria-hidden="true">
          <svg viewBox="0 0 48 48" role="img">
            <path d="M24 4.5c-10.8 0-19.5 8.7-19.5 19.5 0 8.6 5.6 15.9 13.3 18.5 1 .2 1.3-.4 1.3-.9v-3.5c-5.4 1.2-6.5-2.3-6.5-2.3-.9-2.2-2.1-2.8-2.1-2.8-1.8-1.2.1-1.2.1-1.2 1.9.1 3 2 3 2 1.7 3 4.6 2.1 5.7 1.6.2-1.2.7-2.1 1.2-2.6-4.3-.5-8.8-2.2-8.8-9.6 0-2.1.8-3.9 2-5.2-.2-.5-.9-2.5.2-5.1 0 0 1.6-.5 5.4 2 1.6-.4 3.2-.7 4.8-.7s3.3.2 4.8.7c3.7-2.5 5.4-2 5.4-2 1.1 2.6.4 4.6.2 5.1 1.3 1.4 2 3.1 2 5.2 0 7.5-4.5 9.1-8.8 9.6.7.6 1.3 1.8 1.3 3.6v5.2c0 .5.3 1.1 1.3.9 7.7-2.6 13.3-9.9 13.3-18.5C43.5 13.2 34.8 4.5 24 4.5z" />
          </svg>
        </span>
        <span>
          <strong>Much of my work is open source.</strong>
          <small>You can find it on <span>GitHub</span>.</small>
        </span>
      </a>
      <a href="/contact" class="project-callout">
        <span class="callout-icon" aria-hidden="true">
          <svg viewBox="0 0 48 48" role="img">
            <path d="M7.5 12.5h33v24h-33z" />
            <path d="m8.5 14 15.5 13 15.5-13" />
          </svg>
        </span>
        <span>
          <strong>Have a question or want to work together?</strong>
          <small>Get in touch <span aria-hidden="true">→</span></small>
        </span>
      </a>
    </section>
  </article>
</BaseLayout>
